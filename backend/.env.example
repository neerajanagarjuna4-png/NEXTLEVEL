# ─── NEXT_LEVEL Backend Environment Variables ───────────────
# Copy this file to .env and fill in with your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nextlevel?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=nextlevel_secret_key_change_this_in_production

# Mentor Master Password (for mentor login)
MENTOR_MASTER_PASSWORD=Bhima@123

# Email (Gmail SMTP – use App Password, not real password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
MENTOR_EMAIL=sankar.bhima@gmail.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://next-level-by-bhima-sankar-sir-mentoring.vercel.app
