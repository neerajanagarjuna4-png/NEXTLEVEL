# Production environment variables for NEXT_LEVEL backend
# Copy this file to `.env` or set these vars in your hosting provider (Render, Docker, etc.)

NODE_ENV=production
PORT=5000

# MongoDB connection string (use Atlas SRV URI)
MONGODB_URI=your_production_mongodb_connection_string_here

# JWT secret used to sign auth tokens (use a long random string)
JWT_SECRET=replace_with_strong_random_secret

# Frontend / app URLs
FRONTEND_URL=https://your-frontend.vercel.app
APP_URL=${FRONTEND_URL}

# Vite-friendly frontend envs (for deployment guidance only)
VITE_API_URL=${FRONTEND_URL}/api
VITE_SOCKET_URL=wss://your-backend-host

# Mentor master password (used to provision mentor accounts)
MENTOR_MASTER_PASSWORD=replace_with_secure_master_password

# Email / SMTP (required for invites, notifications)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=supersecretpassword
MENTOR_EMAIL=mentors@yourdomain.com

# Optional / integrations
SENTRY_DSN=
REDIS_URL=
STRIPE_SECRET_KEY=
CLOUDINARY_URL=

# If you use a Postgres service for analytics or other integrations, set the
# connection string here. Do NOT commit real credentials; set this in your
# hosting provider (Render / Vercel) instead.
# Example: postgresql://user:pass@host:5432/dbname?sslmode=require
POSTGRES_URL=

# SECURITY: Never commit real credentials. Keep this file out of Git history.
